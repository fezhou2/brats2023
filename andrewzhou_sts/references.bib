@misc{jungo_assessing_2019,
  title = {Assessing {Reliability} and {Challenges} of {Uncertainty} {Estimations} for {Medical} {Image} {Segmentation}},
  copyright = {arXiv.org perpetual, non-exclusive license},
  url = {https://arxiv.org/abs/1907.03338},
  doi = {10.48550/ARXIV.1907.03338},
  abstract = {Despite the recent improvements in overall accuracy, deep learning systems still exhibit low levels of robustness. Detecting possible failures is critical for a successful clinical integration of these systems, where each data point corresponds to an individual patient. Uncertainty measures are a promising direction to improve failure detection since they provide a measure of a system's confidence. Although many uncertainty estimation methods have been proposed for deep learning, little is known on their benefits and current challenges for medical image segmentation. Therefore, we report results of evaluating common voxel-wise uncertainty measures with respect to their reliability, and limitations on two medical image segmentation datasets. Results show that current uncertainty methods perform similarly and although they are well-calibrated at the dataset level, they tend to be miscalibrated at subject-level. Therefore, the reliability of uncertainty estimates is compromised, highlighting the importance of developing subject-wise uncertainty estimations. Additionally, among the benchmarked methods, we found auxiliary networks to be a valid alternative to common uncertainty methods since they can be applied to any previously trained segmentation model.},
  urldate = {2025-10-01},
  publisher = {arXiv},
  author = {Jungo, Alain and Reyes, Mauricio},
  year = {2019},
  note = {Version Number: 2},
  keywords = {Computer Vision and Pattern Recognition (cs.CV), FOS: Computer and information sciences, FOS: Electrical engineering, electronic engineering, information engineering, Image and Video Processing (eess.IV)}
}

@article{jungo2020,
  title = {On the effect of inter-observer variability for a reliable estimation of uncertainty of medical image segmentation},
  volume = {65},
  issn = {1361-8415},
  url = {https://www.sciencedirect.com/science/article/pii/S136184152030123X},
  doi = {10.1016/j.media.2020.101776},
  abstract = {Uncertainty estimation in medical image segmentation is crucial for clinical decision-making. However, inter-observer variability in expert annotations introduces ambiguity that affects uncertainty calibration. This study quantifies the impact of multi-rater annotations on uncertainty estimation using Monte Carlo Dropout on the BraTS 2018 dataset. Results show RMSD ~0.065 and correlation of 0.68 between predicted uncertainty and observer disagreement, demonstrating that voxel-wise calibration improves with multi-rater ground truth.},
  language = {en},
  urldate = {2025-10-01},
  journal = {Medical Image Analysis},
  author = {Jungo, Alain and Reyes, Mauricio and others},
  year = {2020},
  pages = {101776},
  note = {Reports RMSD ~0.065 and CORR 0.68 on BraTS 2018 using MC Dropout; focuses on voxel-wise calibration with multi-rater errors.}
}

@incollection{savadikar2021,
  title = {Brain Tumour Segmentation Using Probabilistic U-Net},
  booktitle = {Brainlesion: Glioma, Multiple Sclerosis, Stroke and Traumatic Brain Injuries},
  isbn = {978-3-030-72087-2},
  url = {https://link.springer.com/chapter/10.1007/978-3-030-72087-2_22},
  doi = {10.1007/978-3-030-72087-2_22},
  abstract = {This work adapts the Probabilistic U-Net for brain tumor segmentation on BraTS 2020. By incorporating test-time augmentation and conditional variational inference, the model generates diverse plausible segmentations. Uncertainty is quantified via predictive entropy and mutual information. Results show RMSD ~0.053 and correlation of 0.74 between uncertainty and segmentation error, outperforming standard U-Net baselines in uncertainty-aware segmentation.},
  language = {en},
  urldate = {2025-10-01},
  publisher = {Springer},
  author = {Savadikar, Chandan and Kulhalli, Ravi and Garware, Bhushan},
  editor = {Crimi, Alessandro and Bakas, Spyridon and Kuijf, Hugo and Keyvan, Farahani and Reyes, Mauricio and van Walsum, Theo},
  year = {2021},
  pages = {295--304},
  note = {Adapts Probabilistic U-Net for BraTS 2020; RMSD ~0.053, CORR 0.74 via test-time augmentation.}
}

@article{zhang2023,
  title = {Uncertainty-guided transformer for brain tumor segmentation},
  volume = {61},
  issn = {0140-0118, 1741-0444},
  shorttitle = {Uncertainty-guided transformer},
  url = {https://link.springer.com/10.1007/s11517-023-02899-8},
  doi = {10.1007/s11517-023-02899-8},
  abstract = {A transformer-based architecture with evidential deep learning is proposed for uncertainty-aware brain tumor segmentation on BraTS 2021. Modality-aware fusion and uncertainty-guided attention refine feature representations. The model outputs both segmentation and epistemic/aleatoric uncertainty maps. Results show RMSD ~0.046 and correlation of 0.70, with uncertainty highly correlated with segmentation errors in ambiguous regions.},
  language = {en},
  number = {12},
  urldate = {2025-10-01},
  journal = {Medical \& Biological Engineering \& Computing},
  author = {Zhang, Y. and Yang, J. and Tian, J. and others},
  month = dec,
  year = {2023},
  pages = {3289--3301},
  note = {Evidential deep learning on BraTS 2021; RMSD ~0.046, CORR 0.70 with modality-aware fusion.}
}

@article{mehta2024,
  title = {{QU}-{BraTS}: {MICCAI} {BraTS} 2023 {Challenge} on {Quantifying} {Uncertainty} in {Brain} {Tumor} {Segmentation} -- {Analysis} of {Ranking} {Scores} and {Benchmarking} {Results}},
